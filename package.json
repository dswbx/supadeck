{
   "name": "supadeck",
   "version": "0.0.4",
   "description": "Zero-config MDX presentations with hot reload and PDF export.",
   "type": "module",
   "types": "./dist/index.d.ts",
   "bin": {
      "supadeck": "./dist/cli/index.js"
   },
   "exports": {
      ".": "./dist/index.js"
   },
   "files": [
      "dist",
      "README.md"
   ],
   "scripts": {
      "build": "tsc -p tsconfig.build.json && node ./scripts/copy-static.mjs",
      "dev": "SUPADECK_DEFAULT_INPUT=examples/dev tsx ./src/cli/index.ts",
      "export": "SUPADECK_DEFAULT_INPUT=examples/dev tsx ./src/cli/index.ts export",
      "smoke:npx": "npm run build && node ./scripts/smoke-npx.mjs",
      "test": "vitest run",
      "typecheck": "tsc -p tsconfig.json",
      "prerelease": "npm run test && npm run build",
      "release:patch": "npm run prerelease && npm version patch && git push && git push origin --tags && npm publish",
      "release:minor": "npm run prerelease && npm version minor && git push && git push origin --tags && npm publish",
      "release:major": "npm run prerelease && npm version major && git push && git push origin --tags && npm publish"
   },
   "keywords": [
      "mdx",
      "slides",
      "presentations",
      "vite",
      "tailwind"
   ],
   "license": "MIT",
   "dependencies": {
      "@base-ui-components/react": "^1.0.0-rc.0",
      "@mdx-js/rollup": "^3.1.0",
      "@tailwindcss/vite": "^4.1.0",
      "@vitejs/plugin-react": "^5.0.0",
      "gray-matter": "^4.0.3",
      "playwright": "^1.54.0",
      "react": "^19.1.0",
      "react-dom": "^19.1.0",
      "remark-gfm": "^4.0.1",
      "remark-mdx": "^3.1.0",
      "remark-parse": "^11.0.0",
      "tailwindcss": "^4.1.0",
      "unified": "^11.0.5",
      "vite": "^7.0.0"
   },
   "devDependencies": {
      "@types/node": "^24.0.0",
      "@types/react": "^19.1.0",
      "@types/react-dom": "^19.1.0",
      "tsx": "^4.19.0",
      "typescript": "^5.8.0",
      "vitest": "^3.2.4"
   }
}
